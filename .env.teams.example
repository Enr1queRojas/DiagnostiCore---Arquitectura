# Teams Bot — Variables de entorno
# Copia este archivo a .env.teams y llena los valores reales.
# .env.teams está en .gitignore — nunca lo subas al repo.

# ── Microsoft Bot Framework ────────────────────────────────────────────────
MicrosoftAppId=17e9759e-bfa0-4379-bc78-52933552745f
MicrosoftAppPassword=<tu-client-secret-de-azure>
MicrosoftTenantId=<tu-tenant-id>   # Azure Entra ID → Overview → Directory (tenant) ID

# ── DiagnostiCore API ──────────────────────────────────────────────────────
# URL base donde corre api/app.py (uvicorn)
DIAGNOSTICORE_API_URL=http://localhost:8000

# ── Bot server ─────────────────────────────────────────────────────────────
BOT_PORT=3978
